{{!
    @template theme_poli/hero

    Front page hero banner.
}}
<section class="poli-hero mb-4">
    <span class="poli-hero-image-layer"></span>
    <span class="poli-hero-scrim"></span>
    <div class="poli-container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <h1>{{{ heroheading }}}</h1>
                <p class="poli-hero-lead">{{ herosubheading }}</p>
                <div class="poli-hero-actions">
                    {{#hasherobutton}}
                        <a href="{{ herobuttonurl }}" class="btn btn-poli btn-lg">
                            {{ herobuttontext }}
                            <i class="fa fa-arrow-right ms-2" aria-hidden="true"></i>
                        </a>
                    {{/hasherobutton}}
                    {{^hasherobutton}}
                        <a href="{{ loginurl }}" class="btn btn-poli btn-lg">
                            {{ herobuttontext }}
                            <i class="fa fa-arrow-right ms-2" aria-hidden="true"></i>
                        </a>
                    {{/hasherobutton}}
                    <a href="{{ allcoursesurl }}" class="btn btn-poli-ghost btn-lg">
                        {{#str}} viewallcourses, theme_poli {{/str}}
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="poli-hero-art" aria-hidden="true">
                    <div class="poli-hero-tile"><i class="fa fa-graduation-cap"></i></div>
                    <div class="poli-hero-tile"><i class="fa fa-flask"></i></div>
                    <div class="poli-hero-tile"><i class="fa fa-book-open"></i></div>
                    <div class="poli-hero-tile"><i class="fa fa-laptop-code"></i></div>
                </div>
            </div>
        </div>
    </div>
</section>
