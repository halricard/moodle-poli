{{!
    @template theme_poli/coursehero

    Course presentation hero shown above the course content.
}}
<section class="poli-course-hero" style="--poli-card-start: {{ accentstart }}; --poli-card-end: {{ accentend }};">
    {{#hasimage}}
        <span class="poli-course-hero-bg" style="background-image: url('{{ imageurl }}');"></span>
        <span class="poli-course-hero-scrim"></span>
    {{/hasimage}}

    {{#categoryname}}
        <a class="poli-course-hero-cat" href="{{ categoryurl }}">
            <i class="fa fa-folder-open" aria-hidden="true"></i> {{ categoryname }}
        </a>
    {{/categoryname}}

    <h1>{{ fullname }}</h1>

    {{#summary}}
        <p class="poli-course-hero-summary">{{ summary }}</p>
    {{/summary}}

    <div class="poli-course-hero-meta">
        {{#hasteachers}}
            <div class="d-flex align-items-center gap-2">
                <div class="poli-teachers">
                    {{#teachers}}
                        <img src="{{ picture }}" alt="{{ name }}" title="{{ name }}">
                    {{/teachers}}
                </div>
                <span class="poli-teachers-label">
                    {{#str}} taughtby, theme_poli {{/str}}
                    {{#teachers}}<strong>{{ name }}</strong> {{/teachers}}
                </span>
            </div>
        {{/hasteachers}}

        {{#hasprogress}}
            <div class="poli-course-progress">
                <div class="poli-progress-head">
                    <span>{{#str}} courseprogress, theme_poli {{/str}}</span>
                    <span>{{ progress }}%</span>
                </div>
                <div class="progress" role="progressbar" aria-valuenow="{{ progress }}" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar" style="width: {{ progress }}%;"></div>
                </div>
            </div>
        {{/hasprogress}}

        {{! Enrolled learners with a resumable activity jump straight into it;
            everyone else just scrolls to the course content. }}
        {{#resumeurl}}
            <a href="{{ resumeurl }}" class="btn btn-poli-ghost ms-auto">
                {{#str}} continuelearning, theme_poli {{/str}}
                <i class="fa fa-arrow-right ms-2" aria-hidden="true"></i>
            </a>
        {{/resumeurl}}
        {{^resumeurl}}
            <a href="#poli-course-content" class="btn btn-poli-ghost ms-auto">
                {{#isenrolled}}{{#str}} continuelearning, theme_poli {{/str}}{{/isenrolled}}
                {{^isenrolled}}{{#str}} accesscourse, theme_poli {{/str}}{{/isenrolled}}
                <i class="fa fa-arrow-down ms-2" aria-hidden="true"></i>
            </a>
        {{/resumeurl}}
    </div>
</section>
