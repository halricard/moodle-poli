{{!
    @template theme_boost/footer

    Poli branded footer.
}}
<footer id="page-footer" class="poli-footer">
    <div class="poli-container">
        <div class="poli-footer-grid">
            <div class="poli-footer-brand">
                <span class="poli-footer-logo">{{{ sitename }}}</span>
                <p class="poli-footer-tagline">{{#str}} footertagline, theme_poli {{/str}}</p>
                <div class="poli-footer-social">
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f" aria-hidden="true"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram" aria-hidden="true"></i></a>
                    <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube" aria-hidden="true"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in" aria-hidden="true"></i></a>
                </div>
            </div>

            <nav class="poli-footer-col" aria-label="{{#str}} footerexplore, theme_poli {{/str}}">
                <h4>{{#str}} footerexplore, theme_poli {{/str}}</h4>
                <a href="{{ config.wwwroot }}/?redirect=0">{{#str}} footerhome, theme_poli {{/str}}</a>
                <a href="{{ config.wwwroot }}/course/index.php">{{#str}} footercourses, theme_poli {{/str}}</a>
                <a href="{{ config.wwwroot }}/course/index.php">{{#str}} footercategories, theme_poli {{/str}}</a>
                <a href="{{ config.wwwroot }}/my/courses.php">{{#str}} footermycourses, theme_poli {{/str}}</a>
            </nav>

            <div class="poli-footer-col">
                <h4>{{#str}} footerhelp, theme_poli {{/str}}</h4>
                {{# output.supportemail }}
                    <div class="poli-footer-support">{{{ output.supportemail }}}</div>
                {{/ output.supportemail }}
                {{# output.page_doc_link }}
                    <div class="poli-footer-support">{{{ output.page_doc_link }}}</div>
                {{/ output.page_doc_link }}
            </div>
        </div>

        <div class="poli-footer-bottom">
            <span>&copy; <span data-poli-year>2026</span> {{{ sitename }}}. {{#str}} footerrights, theme_poli {{/str}}</span>
            <span class="poli-footer-powered">{{#str}} poweredbymoodle, core {{/str}}</span>
        </div>

        <div class="poli-footer-meta">
            {{{ output.standard_footer_html }}}
        </div>
    </div>

    <div class="footer-content-debugging">
        {{{ output.debug_footer_html }}}
    </div>

    {{{ output.standard_end_of_body_html }}}
</footer>
{{#js}}
require(['core/copy_to_clipboard']);
document.querySelectorAll('[data-poli-year]').forEach(function(el) {
    el.textContent = new Date().getFullYear();
});
{{/js}}
