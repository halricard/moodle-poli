{{!
    @template theme_boost/head

    Poli override of the page head. Forces the dark colour scheme before the
    first paint, then renders the standard Moodle head content.
}}
{{{ output.doctype }}}
<html {{{ output.htmlattributes }}}>
<head>
    <script>
    //<![CDATA[
    (function() {
        var root = document.documentElement;
        // Apply dark before first paint to avoid Bootstrap's light defaults.
        root.setAttribute('data-bs-theme', 'dark');
        root.style.colorScheme = 'dark';
        try {
            localStorage.removeItem('poli-color-scheme');
        } catch (e) {
            // Storage unavailable; dark is already applied.
        }
    })();
    //]]>
    </script>
    <title>{{{ output.page_title }}}</title>
    <link rel="shortcut icon" href="{{{ output.favicon }}}" />
    <meta name="color-scheme" content="dark">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700;800&display=swap">

    {{{ output.standard_head_html }}}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
