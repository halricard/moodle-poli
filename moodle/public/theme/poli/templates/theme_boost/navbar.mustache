{{!
    @template theme_boost/navbar

    Poli override of the top navbar. Identical structure to Boost with an added
    light/dark colour scheme toggle.
}}
<nav class="navbar fixed-top bg-body navbar-expand" aria-label="{{#str}}sitemenubar, admin{{/str}}">
    <div class="container-fluid">
        <button class="navbar-toggler aabtn d-block d-md-none px-1 my-1 border-0" data-toggler="drawers" data-action="toggle" data-target="theme_boost-drawers-primary">
            <span class="navbar-toggler-icon"></span>
            <span class="visually-hidden">{{#str}}sidepanel, core{{/str}}</span>
        </button>

        <a href="{{{ config.homeurl }}}" class="navbar-brand d-none d-md-flex align-items-center m-0 me-4 p-0 aabtn">
            {{#haslogo}}
                <img src="{{ logolight }}" class="logo poli-logo poli-logo-light" alt="{{ sitename }}">
                <img src="{{ logodark }}" class="logo poli-logo poli-logo-dark" alt="{{ sitename }}">
            {{/haslogo}}
            {{^haslogo}}
                {{# output.should_display_navbar_logo }}
                    <img src="{{output.get_compact_logo_url}}" class="logo me-1" alt="{{sitename}}">
                {{/ output.should_display_navbar_logo }}
                {{^ output.should_display_navbar_logo }}
                    <span class="poli-wordmark">{{{ sitename }}}</span>
                {{/ output.should_display_navbar_logo }}
            {{/haslogo}}
        </a>
        {{#primarymoremenu}}
            <div class="primary-navigation">
                {{> core/moremenu}}
            </div>
        {{/primarymoremenu}}

        {{# output.page_heading_menu}}
            <ul class="navbar-nav d-none d-md-flex my-1 px-1">
                {{{ output.page_heading_menu }}}
            </ul>
        {{/output.page_heading_menu}}

        <div id="usernavigation" class="navbar-nav ms-auto h-100">
            {{# output.search_box }}
                {{{ output.search_box }}}
                <div class="divider border-start h-75 align-self-center mx-1"></div>
            {{/output.search_box}}

            <button type="button" class="poli-theme-toggle mx-1" data-poli-toggle
                    aria-label="{{#str}}togglecolorscheme, theme_poli{{/str}}"
                    title="{{#str}}togglecolorscheme, theme_poli{{/str}}" aria-pressed="false">
                <i class="poli-icon-dark fa fa-moon" aria-hidden="true"></i>
                <i class="poli-icon-light fa fa-sun" aria-hidden="true"></i>
            </button>
            <div class="divider border-start h-75 align-self-center mx-1"></div>

            {{#langmenu}}
                {{> theme_boost/language_menu }}
                <div class="divider border-start h-75 align-self-center mx-1"></div>
            {{/langmenu}}

            {{^showauthbuttons}}
                {{{ output.edit_switch }}}
                {{# output.navbar_plugin_output }}
                {{{ . }}}
                    <div class="divider border-start h-75 align-self-center mx-1"></div>
                {{/output.navbar_plugin_output}}
                {{#usermenu}}
                    <div class="d-flex align-items-stretch usermenu-container" data-region="usermenu">
                        {{> core/user_menu }}
                    </div>
                {{/usermenu}}
            {{/showauthbuttons}}

            {{#showauthbuttons}}
                <div class="poli-nav-auth d-flex align-items-center gap-2 ms-1">
                    <a href="{{ loginurl }}" class="btn btn-primary btn-sm poli-nav-btn">
                        {{#str}} login, core {{/str}}
                    </a>
                    {{#cansignup}}
                        <a href="{{ signupurl }}" class="btn btn-outline-primary btn-sm poli-nav-btn">
                            {{#str}} startsignup, core {{/str}}
                        </a>
                    {{/cansignup}}
                </div>
            {{/showauthbuttons}}
        </div>
    </div>
</nav>

{{> theme_boost/primary-drawer-mobile }}
