{{!
    @template theme_boost/login

    Poli override of the login-flow page (login, signup, forgot password, MFA).
    Adds a floating colour-scheme toggle since the login layout has no navbar.
}}
{{> theme_boost/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}

<div id="page-wrapper" class="poli-login-wrapper">

    {{{ output.standard_top_of_body_html }}}

    <button type="button" class="poli-theme-toggle poli-login-toggle" data-poli-toggle
            aria-label="{{#str}}togglecolorscheme, theme_poli{{/str}}"
            title="{{#str}}togglecolorscheme, theme_poli{{/str}}" aria-pressed="false">
        <i class="poli-icon-dark fa fa-moon" aria-hidden="true"></i>
        <i class="poli-icon-light fa fa-sun" aria-hidden="true"></i>
    </button>

    <div id="page" class="mt-0 poli-login-page">
        {{> core/login_layout }}
    </div>

    {{{ output.standard_after_main_region_html }}}
    {{{ output.standard_end_of_body_html }}}
</div>

</body>
</html>
{{#js}}
M.util.js_pending('theme_boost/loader');
require(['theme_boost/loader'], function() {
  M.util.js_complete('theme_boost/loader');
});
{{/js}}
