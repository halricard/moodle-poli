{{!
    @template theme_poli/categories

    Front page category explorer grid.
}}
<section class="poli-section">
    <div class="poli-container">
        <div class="poli-section-head">
            <span class="poli-eyebrow"><i class="fa fa-compass" aria-hidden="true"></i> {{#str}} exploresubtitle, theme_poli {{/str}}</span>
            <h2>{{#str}} exploretitle, theme_poli {{/str}}</h2>
        </div>
        <div class="poli-category-grid">
            {{#categories}}
                <a class="poli-category-card" href="{{ url }}"
                   style="--poli-cat-start: {{ accentstart }}; --poli-cat-end: {{ accentend }};">
                    <span class="poli-category-icon"><i class="fa {{ icon }}" aria-hidden="true"></i></span>
                    <span class="poli-category-name">{{ name }}</span>
                    <span class="poli-category-count">{{ coursecountlabel }}</span>
                </a>
            {{/categories}}
        </div>
    </div>
</section>
