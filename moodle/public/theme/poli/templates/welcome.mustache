{{!
    @template theme_poli/welcome

    Personalised dashboard welcome header with quick stats.
}}
<section class="poli-welcome">
    <div class="poli-welcome-intro">
        <span class="poli-welcome-date"><i class="fa fa-calendar-day" aria-hidden="true"></i> {{ date }}</span>
        <h1 class="poli-welcome-title">{{ greeting }}, <span class="poli-text-gradient">{{ firstname }}</span> 👋</h1>
        <p class="poli-welcome-sub">{{#str}} welcomesub, theme_poli {{/str}}</p>
    </div>
    <div class="poli-welcome-stats">
        <a class="poli-stat" href="{{ mycoursesurl }}">
            <span class="poli-stat-icon poli-stat-icon-1"><i class="fa fa-book" aria-hidden="true"></i></span>
            <span class="poli-stat-value">{{ coursecount }}</span>
            <span class="poli-stat-label">{{#str}} statcourses, theme_poli {{/str}}</span>
        </a>
        <div class="poli-stat">
            <span class="poli-stat-icon poli-stat-icon-2"><i class="fa fa-spinner" aria-hidden="true"></i></span>
            <span class="poli-stat-value">{{ inprogresscount }}</span>
            <span class="poli-stat-label">{{#str}} statinprogress, theme_poli {{/str}}</span>
        </div>
        <div class="poli-stat">
            <span class="poli-stat-icon poli-stat-icon-3"><i class="fa fa-trophy" aria-hidden="true"></i></span>
            <span class="poli-stat-value">{{ completedcount }}</span>
            <span class="poli-stat-label">{{#str}} statcompleted, theme_poli {{/str}}</span>
        </div>
    </div>
</section>
